# ══════════════════════════════════════════════════════════════
# zoho-retell-middleware — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────
PORT=3000

# ── Retell AI ─────────────────────────────────────────────────
# Get from: https://app.retellai.com/settings → API Keys
RETELL_API_KEY=key_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Retell AI agent ID
# Get from: https://app.retellai.com/agents
RETELL_AGENT_ID=agent_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Retell AI outbound phone number (E.164 format)
# Get from: https://app.retellai.com/phone-numbers
RETELL_FROM_NUMBER=+1XXXXXXXXXX

# ── Zoho CRM OAuth ────────────────────────────────────────────
# Create a Server-Based OAuth app at:
# https://api-console.zoho.in → Add Client → Server-based Applications
#
# Required Scopes:
#   ZohoCRM.modules.leads.ALL
#   ZohoCRM.modules.leads.READ
#   ZohoCRM.modules.leads.UPDATE
#   ZohoCRM.send_mail
#
ZOHO_CLIENT_ID=1000.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ZOHO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ZOHO_REFRESH_TOKEN=1000.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Zoho API domain — use the one matching your data center:
#   India:   https://www.zohoapis.in
#   US:      https://www.zohoapis.com
#   EU:      https://www.zohoapis.eu
#   AU:      https://www.zohoapis.com.au
ZOHO_API_DOMAIN=https://www.zohoapis.in

# ── Security ──────────────────────────────────────────────────
# A strong random secret — must match what you put in the
# Zoho CRM Webhook body as "webhook_secret".
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=replace_with_strong_random_secret_min_32_chars

# ── Email ─────────────────────────────────────────────────────
# From email address for booking link emails
FROM_EMAIL=info@makeyourlabel.com
